{
  "name": "pdf-editor-ultimate",
  "private": true,
  "version": "0.1.0",
  "description": "PDF Editor Ultimate — free, private, in-browser PDF editor. Edit text, fill forms, sign, annotate, merge, and reorder PDFs. Your files never leave your device.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/mahbub-alam-prithibi/pdf-editor-ultimate",
  "keywords": [
    "pdf",
    "pdf-editor",
    "pdf-viewer",
    "merge-pdf",
    "privacy",
    "client-side",
    "react",
    "vite"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "make-sample": "node scripts/make-sample.mjs",
    "make-form-sample": "node scripts/make-form-sample.mjs"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
